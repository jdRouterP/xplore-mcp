{
  "name": "@debridge-finance/debridge-mcp",
  "version": "0.1.3",
  "description": "deBridge MCP server",
  "type": "module",
  "main": "dist/index.js",
  "bin": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "dev:http": "MCP_TRANSPORT=http PORT=3000 tsx src/index.ts",
    "start": "node dist/index.js",
    "start:http": "MCP_TRANSPORT=http node dist/index.js",
    "inspect": "npx @modelcontextprotocol/inspector tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "api-validate": "tsx scripts/api-validate.ts"
  },
  "keywords": [
    "debridge",
    "dln",
    "mcp",
    "cross-chain",
    "bridge",
    "defi",
    "swap"
  ],
  "author": "deBridge",
  "license": "MIT",
  "files": [
    "dist",
    "data",
    "LICENSE",
    "README.md",
    "SKILL.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/debridge-finance/debridge-mcp.git"
  },
  "mcpName": "io.github.debridge-finance/debridge-mcp",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.26.0",
    "express": "^5.2.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^22.19.9",
    "@types/supertest": "^6.0.3",
    "supertest": "^7.2.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
